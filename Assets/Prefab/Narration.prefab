--- !u!114 &4199914899064487305
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2926633565945616190}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 69adabf6bc9ad794aa0e7498f9b691db, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueManager
  dialoguePanel: {fileID: 6075945983424042143}
  dialogueText: {fileID: 7700735302395547705}
  sentences:
  - "\u2026\u2026\uC544. \uB098\uB294 \uC8FD\uC5C8\uAD6C\uB098."
  - "\uAE30\uC5B5\uB098\uB294 \uAC83\uC740 \uC544\uBB34\uAC83\uB3C4 \uC5C6\uB2E4.\n\uB0B4\uAC00
    \uB204\uAD6C\uC600\uB294\uC9C0, \uC65C \uC774\uACF3\uC5D0\uC11C \uC8FD\uC5C8\uB294\uC9C0\uC870\uCC28.\r\n"
  - "\uB2E4\uB9CC, \uBA38\uB9BF\uC18D\uC744 \uAC00\uB4DD \uCC44\uC6B4 \uC0DD\uAC01\uC740
    \uC624\uC9C1 \uD558\uB098\uBFD0\uC774\uB2E4. '\uBAA8\uB780'"
  - "\uBC14\uB2E5\uC5D0\uB294 \uC720\uC11C\uAC00 \uB5A8\uC5B4\uC838\uC788\uB2E4.
    \n\uC720\uC11C\uC758 \uB0B4\uC6A9\uC744 \uC77D\uC5B4\uBCF4\uB2C8 \uBB38\uC7A5\uC774
    \uB208\uC5D0 \uB4E4\uC5B4\uC628\uB2E4."
  - "\u201C\u2026\uC0AC\uB791\uD558\uB358 \uBAA8\uB780\uC774 \uC9C0\uB358 \uB0A0,
    \uC138\uC0C1\uB3C4 \uD568\uAED8 \uBB34\uB108\uC84C\uB2E4. \n\uBD89\uAC8C \uBB3C\uB4E0
    \uADF8 \uD6C4\uAD81\uC804\uC758 \uB730\uC5D0 \uB0B4 \uB9C8\uC9C0\uB9C9 \uC228\uC744
    \uBB3B\uB294\uB2E4. \n\uBAA8\uB780\uC774 \uB2E4\uC2DC \uD750\uB4DC\uB7EC\uC9C0\uAC8C
    \uD53C\uC5B4\uB0A0 \uB54C, \uB2F9\uC2E0\uC740 \uB098\uB97C \uAE30\uC5B5\uD560\uAE4C\u2026\u201D"
  - "\uB204\uAD70\uAC00\uC758 \uC808\uB9DD\uC774 \uB2F4\uAE34 \uC720\uC11C.\r\n\uADF8\uB9AC\uACE0
    \uC5EC\uAE30\uC5D0\uB3C4 \uC5B4\uAE40\uC5C6\uC774 '\uBAA8\uB780'\uC774\uB77C\uB294
    \uB2E8\uC5B4\uAC00 \uC801\uD600 \uC788\uB2E4."
  - "\uBA38\uB9BF\uC18D\uC758 \uC794\uC0C1\uC774 \uAC70\uC138\uAC8C \uC694\uB3D9\uCE5C\uB2E4.
    \uC774\uAC74 \uC6B0\uC5F0\uC774 \uC544\uB2C8\uC57C."
  - "\uBAA8\uB780\uC774 \uAC00\uB4DD \uD53C\uC5B4\uC788\uB294 '\uD6C4\uAD81\uC804'\uC73C\uB85C
    \uAC00\uC57C\uB9CC \uD560 \uAC83 \uAC19\uB2E4. "
  - "\uADF8\uACF3\uC5D0 \uB0B4 \uC783\uC5B4\uBC84\uB9B0 \uAE30\uC5B5\uC758 \uC2E4\uB9C8\uB9AC\uAC00
    \uC788\uC744\uC9C0\uB3C4 \uBAB0\uB77C."
